# Postgres
DATABASE_URL=postgres://message_hub:message_hub@localhost:5435/message_hub

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_SECRET=change-me-in-production

# Encryption key for channel credentials (32-byte base64 key, generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=change-me-32-byte-base64-key

# API
API_PORT=3001

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
