# URL the browser can reach the API at (used both by `next dev`/`next build`
# and by docker-compose as a build ARG — see Dockerfile).
NEXT_PUBLIC_API_URL=http://localhost:3001

# Host-side port docker-compose.yml publishes the container on — only
# needed when the default (4001) is already taken by another app on a
# shared server. Leave unset to use the default.
# FRONTEND_HOST_PORT=4001
