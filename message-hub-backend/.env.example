# Postgres
DATABASE_URL=postgres://message_hub:message_hub@localhost:5435/message_hub

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Host-side ports docker-compose.yml publishes containers on — only needed
# when the defaults (5435/6379/4011) are already taken by another app on a
# shared server. Leave unset to use the defaults.
# POSTGRES_HOST_PORT=5435
# REDIS_HOST_PORT=6379
# API_HOST_PORT=4011

# Auth — required, no insecure default. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=
# Seeded on first boot if no users exist yet for the org — change the password after first login.
ADMIN_EMAIL=admin@giftzone.vn
ADMIN_PASSWORD=change-me-strong-password

# Encryption key for channel credentials (32-byte base64 key, generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=change-me-32-byte-base64-key

# API
API_PORT=3001
# Origin the browser dashboard is served from — used for CORS on both the
# HTTP API and the WebSocket gateway. Must match exactly (scheme+host+port).
FRONTEND_URL=http://localhost:3000
# Base URL end-users/email clients can reach the API at (open-pixel + link
# wrapping in sent messages) — different from any docker-internal hostname.
# Leave unset to disable link-wrapping/open-pixel injection entirely.
PUBLIC_API_URL=http://localhost:3001

# WhatsApp Cloud API webhook subscription handshake (Meta's hub.verify_token)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-me-whatsapp-webhook-verify-token
